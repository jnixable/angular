<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="002-seed-user-alice" author="volodymyr_lushchyk">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
          SELECT COUNT(*)
          FROM users
          WHERE pcode = '32051929971'
      </sqlCheck>
    </preConditions>
    <insert tableName="users">
      <column name="pcode" value="32051929971"/>
      <column name="firstname" value="Alice"/>
      <column name="lastname" value="Andersson"/>
      <column name="email" value="alice@swedapp.com"/>
      <!-- password : alice1234 -->
      <column name="password" value="$2a$10$Eh0mQ8l8i5Tg88AsSOY98.dwugk/U34uaTjZTrpQkhHNdjhn/mFqK"/>
    </insert>
  </changeSet>

  <changeSet id="003-seed-user-bob" author="volodymyr_lushchyk">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*)
        FROM users
        WHERE pcode = '32051929972'
      </sqlCheck>
    </preConditions>
    <insert tableName="users">
      <column name="pcode" value="32051929972"/>
      <column name="firstname" value="Bob"/>
      <column name="lastname" value="Bergstrom"/>
      <column name="email" value="bob@swedapp.com"/>
      <!-- password : bob1234 -->
      <column name="password" value="$2a$10$muerW9pK.RC2Am.j584nBepeLmfRmcI3/XqoF2Eho/0lyUHDg7xPC"/>
    </insert>
  </changeSet>
</databaseChangeLog>
